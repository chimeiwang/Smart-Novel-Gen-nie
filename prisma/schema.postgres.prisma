generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(cuid())
  username             String         @unique
  passwordHash         String
  creditBalanceMicros  BigInt         @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  novels               Novel[]
  tokenUsages          TokenUsage[]
  creditLedgerEntries  CreditLedger[]
}

model Novel {
  id             String              @id @default(cuid())
  name           String
  summary        String?
  storyProgress  String?             // 故事进展，最多3万字
  appliedStyleId String?
  userId         String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  appliedStyle   WritingStyle?       @relation(fields: [appliedStyleId], references: [id])
  chapters       Chapter[]
  characters     Character[]
  items          Item[]
  locations      Location[]
  factions       Faction[]
  glossaries     Glossary[]
  storyBackground StoryBackground?
  worldSetting   WorldSetting?
  writingBible   WritingBible?
  outline        Outline?
  plotProgress   PlotProgress?
  references     ReferenceMaterial[]
  ragDocuments   RagDocument[]
  ragChunks      RagChunk[]
  // 智能写作相关
  foreshadowings Foreshadowing[]
  outlineNodes   OutlineNode[]
  writingConfig  WritingConfig?
  writingTasks   WritingTask[]
  writingSessions WritingSession[]
  workflowRuns    WorkflowRun[]
  writingGoals    ChapterWritingGoal[]

  @@index([userId])
}

model Chapter {
  id              String   @id @default(cuid())
  novelId         String
  title           String
  content         String   @default("")
  order           Int
  status          String   @default("drafting") // drafting | review | completed
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterProgress ChapterProgress?
  qualityChecks   ChapterQualityCheck[]
  writingTasks    WritingTask[]
  writingSessions WritingSession[]
  writingGoals    ChapterWritingGoal[]
  beatPlans       ChapterBeatPlan[]

  @@index([novelId, order])
  @@index([status])
}

// 章节完成后的质量检查队列
model ChapterQualityCheck {
  id        String   @id @default(cuid())
  chapterId String
  type      String   // consistency | lore_sync | editorial | craft
  status    String   @default("pending") // pending | running | completed | skipped
  title     String
  summary   String?
  result    String?
  scoreHook Int?
  scoreTension Int?
  scorePayoff Int?
  scorePacing Int?
  scoreEndingHook Int?
  scoreReaderPromise Int?
  scoreOverall Int?
  qualityGate String? // pass | revise | rewrite
  rewriteBrief String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, type])
  @@index([chapterId])
  @@index([status])
}

// 章节进展
model ChapterProgress {
  id        String   @id @default(cuid())
  chapterId String   @unique
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

// 角色
model Character {
  id                String                @id @default(cuid())
  novelId           String
  name              String
  aliases           String?
  gender            String?
  age               String?
  appearance        String?
  personality       String?
  identity          String?
  background        String?
  factionId         String?

  // 新增：角色不变量（用于 OOC 校验，不应被近期剧情轻易覆盖）
  coreDesire        String?               // 核心欲望/长期驱动力
  behaviorBoundaries String?              // 行为边界/不会做什么
  speechStyle       String?               // 说话习惯
  relationshipPrinciples String?          // 关键关系原则
  shortTermGoal     String?               // 当前短期目标

  // 新增：实力相关
  powerLevel        String?               // 修炼等级/实力等级（如：筑基期、金丹期）
  combatAbility     String?               // 战斗能力描述
  specialSkills     String?               // 特殊技能/能力

  // 新增：当前状态
  currentStatus     CharacterStatus       @default(active)  // active | missing | dead | imprisoned | unknown
  statusNote        String?               // 状态备注（如：失踪原因、死亡时间）

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  novel             Novel                 @relation(fields: [novelId], references: [id], onDelete: Cascade)
  faction           Faction?              @relation(fields: [factionId], references: [id])
  outgoingRelations CharacterRelation[]   @relation("CharacterRelations")
  incomingRelations CharacterRelation[]   @relation("CharacterTargets")
  items             Item[]
  experiences       CharacterExperience[]
  stateChanges      CharacterStateChange[]

  @@index([novelId])
  @@index([factionId])
  @@index([currentStatus])
}

// 角色状态枚举
enum CharacterStatus {
  active      // 活跃/存活
  missing     // 失踪
  dead        // 死亡
  imprisoned  // 被囚禁
  unknown     // 未知/未提及
}

// 人物关系
model CharacterRelation {
  id            String              @id @default(cuid())
  characterId   String
  targetId      String
  relationType  RelationType        // 关系类型枚举
  intimacy      Int                 @default(0)  // 关系亲密度 0-100
  description   String?             // 关系详细描述
  startDate     String?             // 关系建立时间/章节
  endDate       String?             // 关系结束时间/章节（如死亡、背叛）
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  character     Character           @relation("CharacterRelations", fields: [characterId], references: [id], onDelete: Cascade)
  target        Character           @relation("CharacterTargets", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([targetId])
  @@index([relationType])
}

// 关系类型枚举
enum RelationType {
  family        // 家族关系（父子、兄弟等）
  master_student // 师徒
  friend        // 朋友
  enemy         // 敌对
  ally          // 盟友
  lover         // 恋人/伴侣
  rival         // 竞争对手
  subordinate   // 上下级
  acquaintance  // 熟人
  other         // 其他
}

// 角色经历
model CharacterExperience {
  id          String    @id @default(cuid())
  characterId String
  chapterId   String?
  content     String
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([chapterId])
}

// 物品
model Item {
  id           String      @id @default(cuid())
  novelId      String
  name         String
  aliases      String?
  type         String?
  rarity       String?
  effect       String?
  origin       String?
  description  String?
  ownerId      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  novel        Novel       @relation(fields: [novelId], references: [id], onDelete: Cascade)
  owner        Character?  @relation(fields: [ownerId], references: [id])

  @@index([novelId])
  @@index([ownerId])
}

// 地点
model Location {
  id                String      @id @default(cuid())
  novelId           String
  name              String
  aliases           String?
  type              String?
  parentId          String?
  climate           String?
  culture           String?
  description       String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  novel             Novel       @relation(fields: [novelId], references: [id], onDelete: Cascade)
  parent            Location?   @relation("LocationHierarchy", fields: [parentId], references: [id])
  children          Location[]  @relation("LocationHierarchy")
  factionBases      Faction[]   @relation("FactionBase")
  factionTerritories Faction[]  @relation("FactionTerritories")

  @@index([novelId])
  @@index([parentId])
}

// 势力
model Faction {
  id           String      @id @default(cuid())
  novelId      String
  name         String
  aliases      String?
  type         String?
  baseId       String?
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  novel        Novel       @relation(fields: [novelId], references: [id], onDelete: Cascade)
  base         Location?   @relation("FactionBase", fields: [baseId], references: [id])
  members      Character[]
  territories  Location[]  @relation("FactionTerritories")

  @@index([novelId])
  @@index([baseId])
}

// 术语
model Glossary {
  id          String    @id @default(cuid())
  novelId     String
  term        String
  definition  String
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  novel       Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
}

// 故事基础背景
model StoryBackground {
  id        String   @id @default(cuid())
  novelId   String   @unique
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

// 世界设定
model WorldSetting {
  id        String   @id @default(cuid())
  novelId   String   @unique
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

// 作品圣经：商业定位与写作约束
model WritingBible {
  id               String   @id @default(cuid())
  novelId          String   @unique
  genre            String?  // 题材/频道，如玄幻、都市、女频古言
  targetReaders    String?  // 目标读者画像
  coreSellingPoint String?  // 核心卖点
  readerPromise    String?  // 对读者的主要承诺
  appealModel      String?  // 爽点/情绪收益模型
  taboo            String?  // 雷点/禁忌/不要写什么
  comparableTitles String?  // 对标作品或参考方向
  notes            String?  // 其他编辑判断
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  novel            Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model Outline {
  id        String   @id @default(cuid())
  novelId   String   @unique
  content   String   @default("")  // 大纲文本内容
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model PlotProgress {
  id              String   @id @default(cuid())
  novelId         String   @unique
  currentStage    String
  currentGoal     String?
  currentConflict String?
  nextMilestone   String?
  updatedAt       DateTime @updatedAt
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

model ReferenceMaterial {
  id        String                @id @default(cuid())
  novelId    String
  title      String
  type       ReferenceMaterialType
  content    String
  sourceUrl  String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  novel      Novel                 @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId, type])
}

model RagDocument {
  id           String            @id @default(cuid())
  novelId      String
  sourceType   RagSourceType
  sourceId     String
  title        String
  contentHash  String
  status       RagDocumentStatus @default(disabled)
  errorMessage String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  novel        Novel             @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chunks       RagChunk[]

  @@unique([sourceType, sourceId])
  @@index([novelId, sourceType])
}

model RagChunk {
  id                 String   @id @default(cuid())
  documentId         String
  novelId            String
  chunkIndex         Int
  text               String
  charCount          Int
  embeddingDimension Int
  embedding          Unsupported("vector")
  createdAt          DateTime @default(now())
  document           RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  novel              Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([novelId])
}

enum RagSourceType {
  reference_material
}

enum RagDocumentStatus {
  disabled
  ready
  failed
}

// 文风主表
model WritingStyle {
  id                   String              @id @default(cuid())
  name                 String
  sourceType           StyleSourceType     @default(manual)

  // 结构化画像字段
  creativeMethodology  String?
  uniqueMarkers        String?
  generationStyle      String?
  expressionFeatures   String?
  styleTraits          String?
  portraitMarkdown     String?

  // 元数据
  originalCharCount    Int                 @default(0)
  usedCharCount        Int                 @default(0)
  truncated            Boolean             @default(false)
  errorMessage         String?

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  references           StyleReference[]
  tasks                StylePortraitTask[]
  novels               Novel[]
}

// 文风参考资料（txt 文件）
model StyleReference {
  id            String        @id @default(cuid())
  styleId       String
  filename      String        // 原始文件名
  filepath      String        // 本地存储路径
  charCount     Int           @default(0)  // 字符数
  status        String        @default("ready")  // ready | error
  errorMessage  String?       // 错误信息

  createdAt     DateTime      @default(now())

  style         WritingStyle  @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@index([styleId])
}

// 画像生成任务
model StylePortraitTask {
  id            String        @id @default(cuid())
  styleId       String
  status        String        @default("pending")  // pending | processing | success | error
  errorMessage  String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  style         WritingStyle  @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@index([styleId])
}

enum ReferenceMaterialType {
  note
  web
  book
  image
  custom
}

enum StyleSourceType {
  manual
  agent
}

// ============================================
// 智能写作相关数据结构
// ============================================

// 伏笔管理
model Foreshadowing {
  id              String              @id @default(cuid())
  novelId         String

  name            String              // 伏笔名称/描述
  plantedAt       String?             // 埋设位置（章节ID或描述）
  plantedContent  String?             // 埋设时的具体内容
  expectedPayoff  String?             // 预期回收方式
  payoffAt        String?             // 回收位置

  status          ForeshadowingStatus @default(active)  // active | paid_off | abandoned

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  novel           Novel               @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
  @@index([status])
}

enum ForeshadowingStatus {
  active      // 活跃伏笔，未回收
  paid_off    // 已回收
  abandoned   // 已废弃
}

// 大纲节点（结构化大纲）
model OutlineNode {
  id                  String             @id @default(cuid())
  novelId             String
  parentId            String?

  title               String             // 节点标题
  content             String?            // 节点内容描述
  order               Int                @default(0) // 排序

  kind                OutlineNodeKind    @default(stage) // stage | plot_unit | chapter_group
  status              OutlineNodeStatus  @default(planned) // planned | in_progress | completed | skipped

  estimatedWordCount  Int?               // 预估字数
  actualWordCount     Int?               // 实际字数
  linkedChapterId     String?            // 关联的章节
  chapterStartOrder   Int?               // 覆盖的起始章节序号（含）
  chapterEndOrder     Int?               // 覆盖的结束章节序号（含）

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  novel               Novel              @relation(fields: [novelId], references: [id], onDelete: Cascade)
  parent              OutlineNode?       @relation("OutlineHierarchy", fields: [parentId], references: [id])
  children            OutlineNode[]      @relation("OutlineHierarchy")

  @@index([novelId])
  @@index([novelId, kind])
  @@index([novelId, kind, chapterStartOrder, chapterEndOrder])
  @@index([parentId])
  @@index([status])
}

enum OutlineNodeKind {
  stage          // 阶段/卷
  plot_unit      // 剧情单元
  chapter_group  // 章节组
}

enum OutlineNodeStatus {
  planned       // 计划中
  in_progress   // 正在写
  completed     // 已完成
  skipped       // 已跳过
}

// 角色状态变更记录
model CharacterStateChange {
  id            String    @id @default(cuid())
  characterId   String
  chapterId     String?

  changeType    String    // 变更类型：appearance | relationship | ability | status | location
  description   String    // 变更描述
  beforeState   String?   // 变更前状态
  afterState    String    // 变更后状态

  createdAt     DateTime  @default(now())

  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([chapterId])
}

// 小说写作配置
model WritingConfig {
  id                String   @id @default(cuid())
  novelId           String   @unique

  defaultWordCount  Int      @default(4000)
  enabledAgents     String   @default("设定,剧情,写作,校验,编辑")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  novel             Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
}

// 写作任务
model WritingTask {
  id                  String   @id @default(cuid())
  novelId             String
  chapterId           String

  targetWordCount     Int      // 本次目标字数
  selectedAgents      String   // 本次选择的 Agent（逗号分隔）
  phase               String   @default("idle")  // idle | active | waiting_call | completed | error

  agentOutputs        String?  // JSON 存储 Agent 输出
  generatedContent    String?  // 生成的正文内容
  finalContent        String?  // 最终采纳内容

  // 对话历史（v3.0 新增，用于Agent间上下文共享）
  conversationHistory String? // JSON: AgentMessage[]

  // 数据更新记录
  foreshadowingUpdates String? // JSON: 新增/更新的伏笔
  outlineUpdates      String?  // JSON: 大纲节点状态更新
  characterChanges    String?  // JSON: 角色状态变更

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  novel               Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter             Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([novelId])
  @@index([chapterId])
}

// 写作会话：记录一次完整的讨论会话
model WritingSession {
  id          String   @id @default(cuid())
  novelId     String
  chapterId   String
  title       String?  // 会话标题，如"玄天宗讨论"
  phase       String   @default("idle") // idle | discussing | generating | recording | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  messages    WritingMessage[]

  @@index([novelId])
  @@index([chapterId])
}

// 写作消息：保存每条对话
model WritingMessage {
  id          String   @id @default(cuid())
  sessionId   String
  role        String   // "user" | "agent" | "system"
  agentId     String?  // agent 类型：host, writer, recorder...
  content     String   // 消息内容
  intent      String?  // 主持人的意图标记（JSON）
  metadata    String?  // 额外数据（JSON）
  parentId    String?  // 父消息ID（用于分支对话）
  createdAt   DateTime @default(now())

  session     WritingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ============================================
// Token 计费
// ============================================

model TokenUsage {
  id               String   @id @default(cuid())
  userId           String
  model            String   @default("")
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  cachedTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  agentId          String?
  novelId          String?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([agentId])
  @@index([novelId])
}

model CreditLedger {
  id                    String   @id @default(cuid())
  userId                String
  type                  String
  amountMicros          BigInt
  balanceAfterMicros    BigInt
  model                 String?
  promptTokens          Int      @default(0)
  completionTokens      Int      @default(0)
  cachedTokens          Int      @default(0)
  totalTokens           Int      @default(0)
  agentId               String?
  novelId               String?
  requestId             String?
  note                  String?
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([type])
  @@index([requestId])
}

model WorkflowRun {
  id              String   @id @default(cuid())
  novelId         String
  chapterId       String
  userId          String?
  kind            String
  status          String   @default("pending")
  sourceType      String?
  sourceId        String?
  currentAgentId  String?
  input           String?
  output          String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  steps           WorkflowStep[]
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
  @@index([chapterId])
  @@index([userId])
  @@index([kind])
  @@index([status])
}

model WorkflowStep {
  id          String   @id @default(cuid())
  runId       String
  agentId     String?
  stepType    String
  status      String   @default("pending")
  input       String?
  output      String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model ChapterWritingGoal {
  id                  String   @id @default(cuid())
  novelId             String
  chapterId           String
  narrativeGoal       String
  desiredEmotion      String?
  requiredForeshadowing String?
  requiredCharacters  String?
  wordCountMin        Int?
  wordCountMax        Int?
  specialNotes        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  beatPlans           ChapterBeatPlan[]
  novel               Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter             Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([novelId, chapterId])
  @@index([chapterId])
}

model ChapterBeatPlan {
  id                      String   @id @default(cuid())
  chapterId               String
  goalId                  String?
  status                  String   @default("draft")
  chapterGoal             String
  mainPlotConnection      String?
  chapterAcceptanceCriteria String?
  totalEstimatedWords     Int      @default(0)
  generatedBy             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  sceneBeats              SceneBeat[]
  chapter                 Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  goal                    ChapterWritingGoal? @relation(fields: [goalId], references: [id])

  @@index([chapterId])
  @@index([status])
}

model SceneBeat {
  id                String   @id @default(cuid())
  beatPlanId        String
  order             Int
  goal              String
  conflict          String?
  characters        String
  foreshadowingRefs String?
  estimatedWords    Int      @default(0)
  acceptanceCriteria String

  beatPlan          ChapterBeatPlan @relation(fields: [beatPlanId], references: [id], onDelete: Cascade)

  @@index([beatPlanId])
}

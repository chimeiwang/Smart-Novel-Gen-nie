# 对外端口和镜像版本
INKFORGE_PORT=80
INKFORGE_IMAGE_TAG=latest

# 现有 PostgreSQL 数据库。迁移过程不会创建、修改或迁移数据库结构。
POSTGRES_USER=inkforge
POSTGRES_PASSWORD=请替换
POSTGRES_DB=inkforge
POSTGRES_DATA_VOLUME=请填写现有数据卷名称
DATABASE_URL=postgresql+asyncpg://inkforge:请替换@postgres:5432/inkforge

# 浏览器会话签名密钥，至少 32 个 UTF-8 字节。
JWT_SECRET=请替换为随机密钥

# 使用 scripts/generate_service_keys.py 生成，目录不得提交到仓库。
SERVICE_KEYS_DIR=./secrets
CORE_SERVICE_KEY_ID=core-api-v1
AGENT_SERVICE_KEY_ID=agent-service-v1

# 模型服务
MODEL_PROVIDER=openai_compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_MODEL=

# 默认关闭人工调试日志读取接口。
WORKFLOW_EVENT_DEBUG_ENABLED=false

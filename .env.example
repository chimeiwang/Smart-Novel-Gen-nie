# 数据库配置
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/novelwriter"

# JWT 密钥（用于会话令牌签名，请修改为随机字符串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# AI 配置（DeepSeek / OpenAI 兼容 API）
OPENAI_API_KEY="your_api_key_here"
OPENAI_BASE_URL="https://api.deepseek.com/v1"
OPENAI_MODEL="deepseek-v4-flash"

# LLM runtime：langchain（默认）或 legacy-openai（回退到旧 OpenAI SDK runtime）
LLM_RUNTIME="langchain"
LLM_LOG_MODE="summary"

# LangSmith 配置（用于 LangGraph 追踪和监控）
# 申请地址：https://smith.langchain.com/
LANGSMITH_API_KEY="your_langsmith_api_key"
LANGSMITH_PROJECT="novel-writer"
LANGSMITH_TRACING="true"
LANGCHAIN_API_KEY="your_langsmith_api_key"
LANGCHAIN_PROJECT="novel-writer"
LANGCHAIN_TRACING_V2="true"

# 项目级 LangSmith 总开关。默认关闭，避免本地长文本流式生成时追踪 token 级事件。
LANGSMITH_TRACING_ENABLED="false"
# LangSmith 端点（可选，默认官方服务）
# LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# LangSmith 验证（可选）
# LANGSMITH_VERIFY_API_KEY="false"

# Agent 观测/调试开关
# 是否写入 logs/workflow-events/*.jsonl。默认关闭；只有需要审计 LangGraph/SSE 事件时才设为 true。
WORKFLOW_EVENT_LOG_ENABLED="false"
# 是否开放 /debug/workflow-events 调试 API/页面。默认关闭并返回 404；需要查看本地 JSONL 回放时设为 true。
WORKFLOW_EVENT_DEBUG_ENABLED="false"
# 是否允许 npm run studio:dev 启动 LangGraph Studio/Agent Server。默认关闭；需要 Studio 调试时设为 true。
LANGGRAPH_STUDIO_ENABLED="false"
# 是否使用 LangGraph streamEvents 驱动实时 SSE。默认开启；关闭后只保留最小 start/done/error 事件。
LANGGRAPH_STREAM_EVENTS_ENABLED="true"
# 是否启用 LangGraph MemorySaver 做当前进程内 interrupt/resume。
LANGGRAPH_MEMORY_SAVER_ENABLED="true"
# 工作流正常完成、草案应用或丢弃后是否清理当前 task 的 MemorySaver checkpoint。
LANGGRAPH_MEMORY_SAVER_CLEANUP_ON_DONE="true"

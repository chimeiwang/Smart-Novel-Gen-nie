{
  "name": "inkforge",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "npm run dev --workspace @inkforge/web",
    "build": "npm run build --workspace @inkforge/web",
    "start": "npm run start --workspace @inkforge/web",
    "lint": "npm run lint --workspace @inkforge/web",
    "typecheck": "npm run typecheck --workspace @inkforge/web && npm run typecheck --workspace @inkforge/api-client",
    "db:generate": "prisma generate && node scripts/sync-prisma-client.mjs",
    "db:generate:pg": "dotenv -e .env.production -- prisma generate --schema=prisma/schema.postgres.prisma && node scripts/sync-prisma-client.mjs",
    "db:push:pg": "dotenv -e .env.production -- prisma db push --schema=prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev",
    "outline:cleanup": "tsx -r tsconfig-paths/register scripts/cleanup-outline-tree.ts",
    "migrate:to-pg": "dotenv -e .env.production -- node scripts/migrate-to-pg.js",
    "start:prod": "npm run start --workspace @inkforge/web",
    "studio:dev": "dotenv -e .env -- node scripts/start-langgraph-studio.mjs",
    "studio:build": "langgraphjs build",
    "studio:input": "tsx -r tsconfig-paths/register scripts/create-langgraph-studio-input.ts",
    "api:generate": "node scripts/generate_api_client.mjs",
    "api:check": "node scripts/generate_api_client.mjs --check",
    "test:web": "npm test --workspace @inkforge/web && npm test --workspace @inkforge/api-client",
    "test:python": "uv run pytest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/api-client"
  ],
  "dependencies": {
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.4",
    "@langchain/langgraph-sdk": "^1.9.23",
    "@langchain/openai": "^1.4.7",
    "@prisma/client": "^6.8.2",
    "antd": "^6.3.6",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "langsmith": "0.5.20",
    "next": "^16.2.1",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.3.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^11.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "openapi-typescript": "^7.10.1",
    "pg": "^8.13.0",
    "prisma": "^6.8.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}

# 本地基础设施
ENVIRONMENT=dev
DATABASE_URL=postgresql+asyncpg://inkforge:请替换@127.0.0.1:5432/inkforge
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=请替换为至少32字节的本地会话密钥

# 本地三服务地址
CORE_API_INTERNAL_URL=http://127.0.0.1:8000
AGENT_SERVICE_URL=http://127.0.0.1:8001
CORE_API_URL=http://127.0.0.1:8000
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
AGENT_SERVICE_CIDRS=127.0.0.1/32,::1/128
TRUSTED_CORE_CIDRS=127.0.0.1/32,::1/128

# 使用服务密钥生成脚本创建，路径相对于仓库根目录
CORE_SERVICE_PRIVATE_KEY_PATH=infra/secrets/core-to-agent-private.pem
AGENT_SERVICE_PUBLIC_KEY_PATH=infra/secrets/agent-to-core-jwks.json
CORE_SERVICE_PUBLIC_KEY_PATH=infra/secrets/core-to-agent-jwks.json
AGENT_SERVICE_PRIVATE_KEY_PATH=infra/secrets/agent-to-core-private.pem

# 本地默认使用不计费的确定性模拟模型
MODEL_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash
